// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Enums ----------
enum PriceUnit {
  trip
  person
}

// ---------- Models ----------
model Provider {
  id           String  @id @default(cuid())
  name         String
  website      String  @unique
  phone        String?
  email        String?
  locationText String?
  lat          Float?
  lng          Float?

  listings Listing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([website])
}

model Listing {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  title        String
  description  String?
  city         String
  state        String?
  lat          Float?
  lng          Float?
  boatType     String?
  boatLengthFt Int?
  capacity     Int?
  amenities    String[] // Postgres text[]
  species      String[] // Postgres text[]
  images       String[] // Postgres text[]

  sourceUrl    String  @unique
  canonicalUrl String?

  variants  TripVariant[]
  leads     Lead[]
  clickouts Clickout[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city, state])
  @@index([providerId])
}

model TripVariant {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  durationHours Int
  isPrivate     Boolean   @default(false) // <- was true
  priceFrom     Int
  priceUnit     PriceUnit @default(person) // <- optional change

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  name      String
  email     String
  phone     String?
  partySize Int?
  date      DateTime?
  notes     String?

  // attribution
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  createdAt DateTime @default(now())

  @@index([listingId])
  @@index([email])
}

model Clickout {
  id        String   @id @default(cuid())
  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  target    String
  userAgent String?
  ip        String?

  createdAt DateTime @default(now())

  @@index([listingId])
}
model Source {
  id              String   @id @default(cuid())
  kind            SourceKind
  operatorName    String
  contactEmail    String?   // optional; good to have
  operatorSiteUrl String?   // public operator/landing homepage
  proofText       String?   // copy/paste’d permission reply
  proofUrl        String?   // link to email/DM screenshot etc.
  status          SourceStatus @default(ACTIVE)

  // Permissions/granularity (what we're allowed to show/sync)
  allowFacts      Boolean  @default(true)   // name, phone, address, trip facts
  allowPrices     Boolean  @default(true)
  allowPhotos     Boolean  @default(false)
  allowLongCopy   Boolean  @default(false)  // paragraphs / blog-like content
  allowSync       Boolean  @default(true)   // permission to auto-sync from site

  // Ops
  lastSyncAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  listings        ListingSource[]
  previewTokens   PreviewToken[]
}

model Listing {
  id            Int       @id @default(autoincrement())
  boatName      String
  captainName   String?
  phone         String?
  locationText  String?
  species       String[]
  durationHours Float?
  priceUSD      Float?
  bookingUrl    String     @unique
  detailUrl     String?
  sourceDomain  String?
  imageUrls     String[]
  description   String?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  sources       ListingSource[]
}

model ListingSource {
  // many-to-many with extra metadata
  id           String   @id @default(cuid())
  listingId    Int
  sourceId     String
  role         ListingSourceRole @default(PRIMARY) // PRIMARY / SECONDARY / MANUAL
  notes        String?
  firstSeenAt  DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  source       Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([listingId, sourceId])
  @@index([sourceId])
}

model PreviewToken {
  id         String   @id @default(cuid())
  token      String   @unique
  sourceId   String
  listingId  Int?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  source     Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

enum SourceKind {
  INTAKE_FORM
  OPERATOR_PERMISSION
  PUBLIC_SYNC
  PARTNER_FEED        // e.g., CSV/Sheet/JSON they share
}

enum SourceStatus {
  ACTIVE
  PAUSED
  REVOKED
}

enum ListingSourceRole {
  PRIMARY
  SECONDARY
  MANUAL
}

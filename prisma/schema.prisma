// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Enums ----------
enum PriceUnit {
  trip
  person
}

// ---------- Models ----------
model Provider {
  id           String  @id @default(cuid())
  name         String
  website      String  @unique
  phone        String?
  email        String?
  locationText String?
  lat          Float?
  lng          Float?

  listings Listing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([website])
}

model Listing {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  title        String
  description  String?
  city         String
  state        String?
  lat          Float?
  lng          Float?
  boatType     String?
  boatLengthFt Int?
  capacity     Int?
  amenities    String[] // Postgres text[]
  species      String[] // Postgres text[]
  images       String[] // Postgres text[]

  sourceUrl    String  @unique
  canonicalUrl String?

  variants  TripVariant[]
  leads     Lead[]
  clickouts Clickout[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sources ListingSource[]

  @@index([city, state])
  @@index([providerId])
}

model TripVariant {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  durationHours Int
  isPrivate     Boolean   @default(false) // <- was true
  priceFrom     Int
  priceUnit     PriceUnit @default(person) // <- optional change

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  name      String
  email     String
  phone     String?
  partySize Int?
  date      DateTime?
  notes     String?

  // attribution
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  createdAt DateTime @default(now())

  @@index([listingId])
  @@index([email])
}

model Clickout {
  id        String   @id @default(cuid())
  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  target    String
  userAgent String?
  ip        String?

  createdAt DateTime @default(now())

  @@index([listingId])
}

model Source {
  id              String       @id @default(cuid())
  kind            SourceKind
  operatorName    String
  contactEmail    String?
  operatorSiteUrl String?
  proofText       String?
  proofUrl        String?
  status          SourceStatus @default(ACTIVE)
  allowFacts      Boolean      @default(true)
  allowPrices     Boolean      @default(true)
  allowPhotos     Boolean      @default(false)
  allowLongCopy   Boolean      @default(false)
  allowSync       Boolean      @default(true)
  lastSyncAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  listings      ListingSource[]
  previewTokens PreviewToken[]
}

model ListingSource {
  id          String            @id @default(cuid())
  listingId   String // 👈 match Listing.id (String cuid)
  sourceId    String
  role        ListingSourceRole @default(PRIMARY)
  notes       String?
  firstSeenAt DateTime          @default(now())
  lastSeenAt  DateTime          @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  source  Source  @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([listingId, sourceId])
  @@index([sourceId])
}

model PreviewToken {
  id        String   @id @default(cuid())
  token     String   @unique
  sourceId  String
  listingId String? // 👈 match Listing.id (String cuid)
  expiresAt DateTime
  createdAt DateTime @default(now())

  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

enum SourceKind {
  INTAKE_FORM
  OPERATOR_PERMISSION
  PUBLIC_SYNC
  PARTNER_FEED
}

enum SourceStatus {
  ACTIVE
  PAUSED
  REVOKED
}

enum ListingSourceRole {
  PRIMARY
  SECONDARY
  MANUAL
}
